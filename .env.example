# Required — the passcode used to unlock your diary. Pick any digits or word.
DIARY_PIN=

# Optional — the name shown on the cover ("Hello, <name>!"). Defaults to "Friend".
VITE_DIARY_NAME=

# Required — provided automatically when you connect a Redis store
# (e.g. the "Upstash for Redis" integration from the Vercel Storage tab).
KV_REST_API_URL=
KV_REST_API_TOKEN=
